@model Candidate

<div > 
    <h3 class="display4">Congrats @Model.FullName </h3>
    <p class="lead">Your application has been <mark>accepted</mark>.</p>
    <p class="lead">Thank you for your interest.</p>
    <blockquote class="blockquote">
        You have enrolled to @Model.SelectedCourse course. 
    </blockquote>
    <p class="text-muted">You applied at @Model.AppliedAt .</p>
    <div class="btn-group">
        <a class="btn btn-outline-success" asp-action="Index">Applications</a>
        <a class="btn btn-success" asp-action="Index" asp-controller="Home">Home</a>
    </div>
</div> 